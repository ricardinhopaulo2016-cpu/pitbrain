# AI Provider: openai | anthropic | mock  (default: openai)
# Use mock para diagnóstico local por regras, sem precisar de API key
AI_PROVIDER=openai
NEXT_PUBLIC_AI_PROVIDER=openai

# OpenAI (default / fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (opcional — ative trocando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Acesso restrito — e-mails autorizados a logar no Pitbrain (separados por vírgula).
# Cadastro público está desativado; crie o usuário manualmente no Supabase Auth
# e liste o e-mail aqui para liberar o login.
PITBRAIN_ALLOWED_EMAILS=

# Meta Marketing API — read-only integration (server-side only, never exposed to the client)
META_ACCESS_TOKEN=
META_API_VERSION=v25.0
META_DEFAULT_AD_ACCOUNT_ID=

# UTMify MCP — read-only integration (server-side only, never exposed to the client). The token
# is embedded in the URL itself as a query param — never commit a real value here or log the URL
# unredacted.
UTMIFY_MCP_URL=
