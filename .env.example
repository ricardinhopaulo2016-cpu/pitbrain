# AI Provider: openai | anthropic | mock  (default: openai)
# Use mock para diagnóstico local por regras, sem precisar de API key
AI_PROVIDER=openai
NEXT_PUBLIC_AI_PROVIDER=openai

# OpenAI (default / fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (opcional — ative trocando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Meta Marketing API — read-only integration (server-side only, never exposed to the client)
META_ACCESS_TOKEN=
META_API_VERSION=v25.0
META_DEFAULT_AD_ACCOUNT_ID=
